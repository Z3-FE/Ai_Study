# ----------------------------------------------------------------------
# 1. 编译和运行时生成的文件
# ----------------------------------------------------------------------
# Python 编译生成的字节码文件
__pycache__/
*.pyc
*.pyd
*.pyo

# 避免生成这些文件，除非有特殊原因
# 如果您在虚拟环境中工作，通常不需要忽略这个，但如果不是，建议忽略
# *.egg-info/
# *.egg

# ----------------------------------------------------------------------
# 2. 虚拟环境
# ----------------------------------------------------------------------
# 忽略常见的虚拟环境目录
venv/
#env/
.venv/
#.env/
# Windows 上的 Anaconda/Miniconda 环境目录
envs/

# ----------------------------------------------------------------------
# 3. 操作系统和编辑器的临时文件
# ----------------------------------------------------------------------
# macOS
.DS_Store
.idea
.history
# Windows
Thumbs.db

# Linux
*~
.#*

# Vim/Nano 备份和交换文件
*.swp
*.swo

# VS Code
.vscode/*
!/.vscode/settings.json # 如果需要共享设置可以保留
!/.vscode/tasks.json
!/.vscode/launch.json
!/.vscode/extensions.json
.vscode/extensions

# JetBrains IDEs (PyCharm, IntelliJ)
.idea/

# ----------------------------------------------------------------------
# 4. 数据和日志文件
# ----------------------------------------------------------------------
# 数据库文件 (如 SQLite)
*.db
*.sqlite
*.sqlite3

# 日志文件
*.log
log/
temp/

# ----------------------------------------------------------------------
# 5. 敏感信息和配置
# ----------------------------------------------------------------------
# 环境变量文件（包含数据库密码、API 密钥等）
.env
.flaskenv
# 敏感配置备份
config.ini.bak
settings.pyc

# ----------------------------------------------------------------------
# 6. Jupyter Notebook & Data Science
# ----------------------------------------------------------------------
# Jupyter Notebook 检查点
.ipynb_checkpoints

# Matplotlib/Seaborn 缓存
.matplotlib/

# ----------------------------------------------------------------------
# 7. 测试和覆盖率报告
# ----------------------------------------------------------------------
# Coverage 报告
.coverage
htmlcov/